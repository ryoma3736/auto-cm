# ============================================
# Auto-CM - 自動広告動画生成システム
# ============================================

# Google Gemini API Key（推奨・画像分析＆スクリプト生成）
# https://makersuite.google.com/app/apikey で取得
GEMINI_API_KEY=your_gemini_api_key_here

# Replicate API Token（動画生成 - Sora 2）
# https://replicate.com/account/api-tokens で取得
# $0.10/秒 の課金（12秒動画 = $1.20）
REPLICATE_API_TOKEN=your_replicate_api_token_here

# ============================================
# オプション設定
# ============================================

# OpenAI API Key（フォールバック用）
# Geminiが使えない場合のバックアップ
# OPENAI_API_KEY=sk-proj-your_openai_key_here

# Google Drive保存（オプション）
# https://console.cloud.google.com/ でサービスアカウント作成
# GOOGLE_DRIVE_CREDENTIALS=./credentials.json

# 出力ディレクトリ
# OUTPUT_DIRECTORY=./output
