# ============================================
# Auto-CM - Sora2自動広告生成システム
# ============================================
# 必要なのはOpenAI APIキーだけ！

# OpenAI API Key（必須）
# https://platform.openai.com/api-keys で取得
# これ1つで以下全てが使えます：
#   - GPT-4 Vision（画像分析）
#   - GPT-4（スクリプト生成）
#   - Sora（動画生成）
OPENAI_API_KEY=sk-proj-your_openai_key_here

# ============================================
# オプション設定
# ============================================

# Google Drive保存（オプション）
# https://console.cloud.google.com/ でサービスアカウント作成
# GOOGLE_DRIVE_CREDENTIALS=./credentials.json

# 出力ディレクトリ
# OUTPUT_DIRECTORY=./output
