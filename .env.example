# AutoCM Studio — environment variables
# Copy to .env.local for local dev, or set in Vercel project settings.

# === Analysis & script (required for real analysis) ===
GEMINI_API_KEY=            # Google Gemini — image analysis + script + Veo 3
# Optional model overrides
# GEMINI_ANALYSIS_MODEL=gemini-2.0-flash
# GEMINI_SCRIPT_MODEL=gemini-2.0-flash
OPENAI_API_KEY=            # optional fallback / TTS

# === Video engines ===
# VEO_MODEL=veo-3.1-fast-generate-preview  # Google Veo model id; swap here when a newer model (e.g. Gemini Omni API) ships
REPLICATE_API_TOKEN=       # Sora 2 + Kling (required for those engines)
ARK_API_KEY=               # ByteDance Seedance (ModelArk)
ARK_ENDPOINT_ID=           # Seedance endpoint id
HEYGEN_API_KEY=            # HeyGen lip-sync
ELEVENLABS_API_KEY=        # optional voice cloning

# === Vercel infra ===
BLOB_READ_WRITE_TOKEN=     # Vercel Blob (media storage)
KV_REST_API_URL=           # Upstash Redis / Vercel KV
KV_REST_API_TOKEN=

# === App ===
# APP_URL=https://auto-cm.vercel.app   # auto-detected from VERCEL_URL in prod
# MOCK_ENGINES=1                        # force sample-video mock for every engine (demo)
