{
  "name": "auto-cm",
  "version": "0.1.0",
  "description": "Sora2 Automatic Advertisement Generation System",
  "type": "module",
  "bin": {
    "auto-cm": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest",
    "test:run": "vitest run",
    "test:pipeline": "vitest run tests/pipeline.test.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "cli": "tsx src/index.ts"
  },
  "keywords": [
    "agentic-os",
    "autonomous",
    "sora2",
    "advertisement",
    "ai",
    "video-generation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@google/generative-ai": "^0.24.1",
    "@types/express": "^5.0.6",
    "@types/multer": "^2.0.0",
    "axios": "^1.7.9",
    "commander": "^14.0.2",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "googleapis": "^144.0.0",
    "multer": "^2.0.2",
    "openai": "^4.77.3",
    "replicate": "^1.4.0",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "tsx": "^4.7.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
